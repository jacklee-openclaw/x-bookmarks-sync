# Required: X user access token with scopes:
# bookmark.read tweet.read users.read
# Optional for link-ingest mode. If empty, the tool falls back to oEmbed.
X_ACCESS_TOKEN=

# Optional API settings
X_API_BASE=https://api.x.com/2
X_MAX_RESULTS=100
X_MAX_PAGES=20
X_REQUEST_TIMEOUT_SEC=30
X_INCLUDE_FOLDERS=1

# Output path (default: ./bookmarks)
BOOKMARKS_ROOT=bookmarks

# Git auto push
GIT_AUTO_PUSH=1
GIT_REMOTE=origin
# GIT_BRANCH=main

# X link -> Markdown knowledge base (new main flow)
KB_ROOT=x-bookmarks
KB_CATEGORIES=ai,eda,verification,career,tools,misc
KB_DEFAULT_CATEGORY=tools
KB_AUTO_GIT_PUSH=1
KB_GIT_REMOTE=origin
KB_GIT_BRANCH=main
