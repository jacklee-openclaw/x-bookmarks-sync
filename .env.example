# Required: X user access token with scopes:
# bookmark.read tweet.read users.read
# Optional for link-ingest mode. If empty, the tool falls back to public endpoints.
X_ACCESS_TOKEN=

# Optional API settings
X_API_BASE=https://api.x.com/2
X_MAX_RESULTS=100
X_MAX_PAGES=20
X_REQUEST_TIMEOUT_SEC=30
X_INCLUDE_FOLDERS=1

# Legacy output path for legacy/sync_bookmarks.py
BOOKMARKS_ROOT=bookmarks

# Legacy git auto push for legacy/sync_bookmarks.py
GIT_AUTO_PUSH=1
GIT_REMOTE=origin
# GIT_BRANCH=main

# Unified contract for x_links_to_kb.py
KB_ROOT=x-bookmarks
KB_STATE_ROOT=.state
KB_CATEGORIES_CONFIG=config/categories.json
KB_TEMPLATE_DIR=templates
KB_MAX_RETRY=2
KB_AUTO_GIT_PUSH=1
KB_GIT_REMOTE=origin
KB_GIT_BRANCH=main
KB_GIT_INCLUDE_STATE=0
KB_SYNC_LIMIT=30

# Content completeness guard + browser fallback (Level 3)
KB_CONTENT_MIN_LEN=120
KB_MIN_ACCEPT_SCORE=70
KB_BROWSER_FALLBACK_ENABLED=1
KB_BROWSER_FALLBACK_TIMEOUT_SEC=25
# Download media files into raw archive when URLs are available
KB_DOWNLOAD_MEDIA=1
KB_MAX_MEDIA_DOWNLOAD=4
# {url} will be replaced with the target link
KB_BROWSER_FALLBACK_CMD='python3 /Users/paipai_1/Work/projects/x_to_cdns/scripts/fetch_with_browser.py {url}'
# Playwright persistent profile (keeps login state)
KB_BROWSER_USER_DATA_DIR=~/.x_to_cdns-browser
KB_BROWSER_HEADLESS=1
